# Protozoan environment variables
# Copy this file to .env in your project root and fill in the values.

# Required: OpenRouter API key (free tier available at https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-...

# Optional: Override the AI model used for code generation.
# Must be a valid OpenRouter model ID (https://openrouter.ai/models).
# Defaults to openrouter/owl-alpha if not set.
# Free-tier options:
#   openrouter/owl-alpha               — default, 1M context, agentic
#   qwen/qwen3-coder:free              — strong at code, may rate limit
#   meta-llama/llama-3.1-8b-instruct:free
#   mistralai/mistral-7b-instruct:free
# Paid options (better quality, no rate limits):
#   anthropic/claude-sonnet-4-5
#   openai/gpt-4o
PROTOZOAN_MODEL=openrouter/owl-alpha
