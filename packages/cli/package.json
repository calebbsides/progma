  "keywords": [
    "ai",
    "developer-tools",
    "overlay",
    "proxy",
    "annotations",
    "vite",
    "nextjs"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "homepage": "https://github.com/calebbsides/progma#readme",
  "repository": {
    "type": "git",
