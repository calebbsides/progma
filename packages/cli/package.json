    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@progma/client": "workspace:*",
    "@progma/server": "workspace:*",
    "dotenv": "^17.4.2",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
